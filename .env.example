# ==============================================================================
# E-Commerce Analytics Platform — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# All variables are optional; defaults come from config.yaml.
# ==============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# Override the SQLite database path (relative or absolute)
ECOM_DB_PATH=db/ecommerce.db

# ── Reports ──────────────────────────────────────────────────────────────────
# Override the default report output directory
ECOM_REPORT_DIR=reports/

# Chart resolution (dots per inch)
ECOM_REPORT_DPI=150

# ── Pipeline ─────────────────────────────────────────────────────────────────
# Batch size for database inserts
ECOM_CHUNK_SIZE=1000

# Maximum query execution time in seconds
ECOM_QUERY_TIMEOUT=30

# Log level: DEBUG, INFO, WARNING, ERROR
ECOM_LOG_LEVEL=INFO

# ── Data Generation ─────────────────────────────────────────────────────────
# Default seed for reproducible synthetic data (leave empty for random)
ECOM_SEED=42

# ── Paths ────────────────────────────────────────────────────────────────────
# Config file path override
ECOM_CONFIG_PATH=config.yaml

# Data input directory
ECOM_DATA_DIR=data/

# Log file directory
ECOM_LOG_DIR=logs/
